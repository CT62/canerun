# Copy to .env.local and fill in real values. Never commit .env.local — it's gitignored.

# Stripe (https://dashboard.stripe.com/apikeys) — use sk_test_... while in test mode,
# swap for sk_live_... only in your production environment's secrets, never in code.
STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook signing secret for this endpoint (https://dashboard.stripe.com/webhooks)
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: only needed if you want the Stripe webhook to auto-create a ShipEngine
# shipping label after checkout. Leave unset to skip that step entirely.
SHIPENGINE_API_KEY=
# JSON-encoded ship-from address, e.g. {"name":"Cane Run Enterprises","address_line1":"...","city_locality":"...","state_province":"KY","postal_code":"...","country_code":"US"}
SHIP_FROM_ADDRESS_JSON=
