# Copy to .env.local and fill in real values. Never commit .env.local — it's gitignored.

# Stripe (https://dashboard.stripe.com/apikeys) — use sk_test_... while in test mode,
# swap for sk_live_... only in your production environment's secrets, never in code.
STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook signing secret for this endpoint (https://dashboard.stripe.com/webhooks)
STRIPE_WEBHOOK_SECRET=whsec_...

# Required to charge live shipping rates on "Ship to Me" checkouts and to auto-purchase
# the ShipStation label + tracking number after checkout. Leave unset to only offer pickup.
# Only your connected FedEx account is quoted — connect one in the ShipStation dashboard.
SHIPENGINE_API_KEY=
# JSON-encoded ship-from address (camelCase keys), e.g.
# {"name":"Cane Run Enterprises","phone":"555-555-5555","addressLine1":"...","cityLocality":"...","stateProvince":"KY","postalCode":"...","countryCode":"US"}
SHIP_FROM_ADDRESS_JSON=

# Resend (https://resend.com/api-keys) — sends the post-checkout order receipt/tracking email.
RESEND_API_KEY=
# Must be an address on a domain verified in Resend, e.g. orders@yourdomain.com
ORDER_FROM_EMAIL=
